    "answer_reveal": {"type": "glitch", "duration": 0.6, "intensity": 1.2},
    "fun_fact": {"type": "typewriter", "duration": 1.8, "intensity": 1.0},
    "outro": {"type": "glow", "duration": 1.0, "intensity": 1.0}
  }
