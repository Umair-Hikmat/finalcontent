{
  "id": "retro_arcade",
  "name": "Retro Arcade",
  "description": "Glitchy, punchy, 8-bit inspired styling with bounce timers and glitch reveals.",
  "background": {
    "type": "particles",
    "color_start": "#0F0C29",
    "color_end": "#302B63",
    "gradient_angle": 60,
    "particle_count": 40,
    "particle_color": "#00FFC6",
    "blur": 0,
    "overlay_opacity": 0.0
  },
  "font": {
    "family": "Press Start 2P",
    "source": "google",
    "size": 42,
    "color": "#00FFC6",
    "bold": false,
    "stroke_color": "#000000",
    "stroke_width": 3
  },
  "timing": {
    "intro": 3.0,
    "question": 4.0,
    "timer": 5.0,
    "answer_reveal": 3.0,
    "fun_fact": 4.0,
    "outro": 3.0
  },
  "render": {
    "format": "shorts",
    "fps": 30,
    "quality": "high"
  },
  "animations": {
